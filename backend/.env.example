# ============================================================
# PECAÊ Backend (Java 25) — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# ============================================================

# ── Database (PostgreSQL via Supabase) ──
DATABASE_URL=jdbc:postgresql://localhost:5432/pecae
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──
JWT_SECRET=dev-secret-key-change-in-production-minimum-256-bits
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ── Google OAuth ──
GOOGLE_CLIENT_ID=

# ── Email (Resend) ──
RESEND_API_KEY=
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
EMAIL_FROM=noreply@pecae.com.br

# ── Supabase Storage ──
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=uploads
STORAGE_TYPE=supabase

# ── Server ──
PORT=8080
CORS_ORIGIN=*

# ── Expo Push ──
EXPO_ACCESS_TOKEN=
